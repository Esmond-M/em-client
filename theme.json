{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                { "slug": "base",          "name": "Base",          "color": "#ffffff" },
                { "slug": "base-2",        "name": "Base 2",        "color": "#f6f6f6" },
                { "slug": "contrast",      "name": "Contrast",      "color": "#111111" },
                { "slug": "contrast-2",    "name": "Contrast 2",    "color": "#444444" },
                { "slug": "primary",       "name": "Primary",       "color": "#0073aa" },
                { "slug": "primary-dark",  "name": "Primary Dark",  "color": "#005177" },
                { "slug": "accent",        "name": "Accent",        "color": "#1a1a1a" },
                { "slug": "accent-2",      "name": "Accent 2",      "color": "#f0f0f0" }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
                    "name": "System Font",
                    "slug": "system-font"
                },
                {
                    "fontFamily": "Georgia, 'Times New Roman', Times, serif",
                    "name": "Serif",
                    "slug": "serif"
                }
            ],
            "fontSizes": [
                { "slug": "small",    "name": "Small",    "size": "0.875rem" },
                { "slug": "medium",   "name": "Medium",   "size": "1rem"     },
                { "slug": "large",    "name": "Large",    "size": "1.25rem"  },
                { "slug": "x-large",  "name": "X-Large",  "size": "1.5625rem" },
                { "slug": "xx-large", "name": "XX-Large", "size": "2.25rem"  },
                { "slug": "huge",     "name": "Huge",     "size": "3rem"     }
            ]
        },
        "spacing": {
            "units": [ "px", "em", "rem", "vh", "vw", "%" ]
        },
        "layout": {
            "contentSize": "760px",
            "wideSize":    "1200px"
        },
        "blocks": {
            "core/button": {
                "color": {
                    "palette": [
                        { "slug": "primary", "name": "Primary", "color": "#0073aa" },
                        { "slug": "accent",  "name": "Accent",  "color": "#1a1a1a" }
                    ]
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text":       "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system-font)",
            "fontSize":   "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.65"
        },
        "spacing": {
            "blockGap": "1.5rem"
        },
        "elements": {
            "link": {
                "color": { "text": "var(--wp--preset--color--primary)" },
                ":hover": {
                    "color": { "text": "var(--wp--preset--color--primary-dark)" }
                }
            },
            "h1": { "typography": { "fontSize": "var(--wp--preset--font-size--huge)",     "fontWeight": "700", "lineHeight": "1.2"  } },
            "h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)",  "fontWeight": "700", "lineHeight": "1.25" } },
            "h3": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)",   "fontWeight": "600", "lineHeight": "1.3"  } },
            "h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)",     "fontWeight": "600"                      } },
            "h5": { "typography": { "fontSize": "var(--wp--preset--font-size--medium)",    "fontWeight": "600"                      } },
            "h6": { "typography": { "fontSize": "var(--wp--preset--font-size--small)",     "fontWeight": "600"                      } }
        },
        "blocks": {
            "core/navigation": {
                "typography": { "fontSize": "var(--wp--preset--font-size--medium)" }
            },
            "core/post-title": {
                "typography": { "fontWeight": "700" }
            },
            "core/site-title": {
                "typography": { "fontWeight": "700", "fontSize": "var(--wp--preset--font-size--large)" }
            }
        }
    },
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" }
    ],
    "customTemplates": [
        { "name": "blank",     "title": "Blank",     "postTypes": ["page", "post"] },
        { "name": "fullwidth", "title": "Full Width", "postTypes": ["page", "post"] }
    ]
}
